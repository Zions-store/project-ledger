{
  "config": {
    "default": true,

    "MD013": { "line_length": 250 },

    // General document-convention conflicts with our source-formatting style
    "MD022": false,
    "MD024": false,
    "MD029": false,
    "MD032": false,
    "MD034": false,
    "MD040": false,
    "MD041": false
  },
  "ignores": [
    "**/tests/fixtures/**",
    "**/node_modules/**",
    "**/.tmp_validation/**",
    "**/.pytest_cache/**"
  ]
}
